<Window x:Class="Obuw12.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:m="clr-namespace:Obuw12.Modeli"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Obuw12"
        mc:Ignorable="d"
         Background="#FFFFFF"
         FontFamily="Arial"
         WindowStartupLocation="CenterScreen"
        Title="Каталог Товаров" Height="600" Width="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="LightGreen">
            <Image Source="/Icon.png" />
            <Button Margin="10,10" Content="Выход" Click="Vihod" Width="80"/>
            <Button Margin="10,10" x:Name="Zakazi" Content="Закази" Click="BthZakazi" Width="80"/>
            <TextBlock x:Name="txtPolzovatel" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
        </StackPanel>

        <StackPanel Margin="10" Grid.Row="1" x:Name="PanelPoiska" Orientation="Horizontal">
            <TextBox x:Name="txtPoisk" Width="200" Margin="5" TextChanged="Poisk" />
            <ComboBox x:Name="ComboFiltr" Width="150" SelectionChanged="Changen" Margin="5"/>
            <ComboBox x:Name="ComboSort" Width="150" SelectionChanged="Changen" Margin="5">
                <ComboBoxItem Content="Без сортировки"/>
                <ComboBoxItem Content="по возростанию"/>
                <ComboBoxItem Content="по убыванию"/>
            </ComboBox>
            <Button Margin="5" x:Name="BthDobavit" Content="Добавить" Click="Dobavit" Width="80"/>
            <Button Margin="5" x:Name="BthRedakt"  Content="Изменить" Click="Redakt" Width="80"/>
            <Button Margin="5" x:Name="BthUdalit" Content="Удалить" Click="Udalit" Width="80"/>
        </StackPanel>

        <ListView Margin="10" x:Name="LvElement" Grid.Row="2" HorizontalContentAlignment="Stretch" MouseDoubleClick="ClickLvElement">
            <ListView.ItemTemplate>
                <DataTemplate >
                    <StackPanel Orientation="Horizontal" Margin="10" Background="{Binding CvetFona}">
                        <Image Width="100" Height="100" Source="{Binding PolniyPutkFoto}"/>
                        <StackPanel Margin="5" Width="600">
                            <TextBlock Text="{Binding Shapka}" FontWeight="Bold" FontSize="16"/>
                            <TextBlock Text="{Binding Opisanie,StringFormat='Описание: {0}'}" />
                            <TextBlock Text="{Binding Proizvoditel.Nazvanie,StringFormat='Производитель: {0}'}" />
                            <TextBlock Text="{Binding Postavchik.Nazvanie,StringFormat='Поставщик: {0}'}" />
                            <TextBlock Text="{Binding TecuchayaCena,StringFormat='Цена: {0}'}" Foreground="Red" TextDecorations="Strikethrough" Visibility="{Binding NormalnayaCena}" />
                            <TextBlock Text="{Binding Cena,StringFormat='{}{0}'}" Visibility="{Binding NormalnayaCena}" />
                            <TextBlock Text="{Binding EdinicaIzmereniya.Nazvanie,StringFormat='Единица измерения: {0}'}" />
                            <TextBlock Text="{Binding Kolichestvo ,StringFormat='Количество на складе: {0}'}" />

                        </StackPanel>
                        <TextBlock Text="{Binding Skidka ,StringFormat='Действующая скидка: {0}%'}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
