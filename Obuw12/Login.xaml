<Window x:Class="Obuw12.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Obuw12"
        mc:Ignorable="d"
        Background="#FFFFFF"
        FontFamily="Arial"
        WindowStartupLocation="CenterScreen"
        Title="Авторизация" Height="450" Width="400">
    <StackPanel Margin="15" VerticalAlignment="Center">
        <TextBlock Text="Авторизация" HorizontalAlignment="Center" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" />
        <TextBlock Text="Логин" Margin="0,0,0,10" />
        <TextBox x:Name="txtLogin" Margin="0,0,0,10"/>
        <TextBlock Text="пароль" Margin="0,0,0,10" />
        <PasswordBox x:Name="txtParol" Margin="0,0,0,20"/>

        <Button Content="Войти" Click="Knopka1" Background="LightGreen" Height="30" Margin="0,0,0,20"/>
        <Button Content="Войти как Гость" Click="Knopka2" Background="Green" Height="30" Margin="0,0,0,20"/>

    </StackPanel>
</Window>
