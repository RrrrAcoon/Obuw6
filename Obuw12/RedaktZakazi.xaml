<Window x:Class="Obuw12.RedaktZakazi"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:m="clr-namespace:Obuw12.Modeli"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Obuw12"
        mc:Ignorable="d"
           Background="#FFFFFF"
           FontFamily="Arial"
           WindowStartupLocation="CenterScreen"
        Title="Заказ" Height="450" Width="600">
    <StackPanel Margin="15">
        <TextBlock x:Name="LbArtikul" Text="Артикул"/>
        <TextBox x:Name="txtArtikul" Text="{Binding Id, Mode=OneWay}" IsReadOnly="True"/>
        <TextBlock Text="Дата Заказа"/>
        <DatePicker SelectedDate="{Binding DataZakaza}"/>
        <TextBlock Text="Дата Выдачи"/>
        <DatePicker SelectedDate="{Binding DataVidachi}"/>
        <TextBlock Text="Пункт выдачи"/>
        <ComboBox x:Name="ComboPunkt" SelectedValue="{Binding PunktVidachiId}" DisplayMemberPath="Adres" SelectedValuePath="Id"/>
        <TextBlock Text="Клиент"/>
        <ComboBox x:Name="ComboClient" SelectedValue="{Binding PolzovatelId}" DisplayMemberPath="FIO" SelectedValuePath="Id"/>
        <TextBlock Text="Статус"/>
        <ComboBox x:Name="ComboStatus" SelectedValue="{Binding StatusZakazaId}" DisplayMemberPath="Nazvanie" SelectedValuePath="Id"/>
        <TextBlock Text="Код"/>
        <TextBox  Text="{Binding KodPolucheniya}" />

        <Button Click="Sohranit" Content="Сохранить" Background="LightGreen" Height="30"/>
    </StackPanel>
</Window>
