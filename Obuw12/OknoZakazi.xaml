<Window x:Class="Obuw12.OknoZakazi"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:m="clr-namespace:Obuw12.Modeli"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Obuw12"
        mc:Ignorable="d"
         Background="#FFFFFF"
         FontFamily="Arial"
         WindowStartupLocation="CenterScreen"
        Title="Закази" Height="600" Width="800">

    <Grid>
        <Grid.RowDefinitions>
        <RowDefinition Height="50"/>
        <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Orientation="Horizontal" Background="LightGreen">
        <Image Source="/Icon.png" />
            <Button Margin="10,10" Content="Назад" Click="BthNazad" Width="80"/>
            <Button Margin="5" x:Name="BthDobavit" Content="Добавить" Click="Dobavit" Width="80"/>
            <Button Margin="5" x:Name="BthRedakt"  Content="Изменить" Click="Redakt" Width="80"/>
            <Button Margin="5" x:Name="BthUdalit" Content="Удалить" Click="Udalit" Width="80"/>
        </StackPanel>

   
    <ListView Margin="10" x:Name="LvElement" Grid.Row="1" HorizontalContentAlignment="Stretch" MouseDoubleClick="ClickLvElement">
        <ListView.ItemTemplate>
            <DataTemplate >
                    <StackPanel Margin="10" Orientation="Horizontal">
                    <StackPanel Margin="5" >
                        <TextBlock Text="{Binding Id,StringFormat='Артикул заказа: {0}'}" FontWeight="Bold" FontSize="16"/>
                        <TextBlock Text="{Binding StatusZakaza.Nazvanie,StringFormat='Статус заказа: {0}'}" />
                        <TextBlock Text="{Binding PunktVidachi.Adres,StringFormat='Адрес пункта выдачи: {0}'}" />
                        <TextBlock Text="{Binding DataZakaza,StringFormat='Дата заказа: {0:dd.MM.yyyy}'}" />
                       
                    </StackPanel>
                        <TextBlock Text="{Binding DataVidachi,StringFormat='Дата заказа: {0:dd.MM.yyyy}'}" 
                        HorizontalAlignment="Center" VerticalAlignment="Center" />
                </StackPanel>
            </DataTemplate>
        </ListView.ItemTemplate>
    </ListView>
    </Grid>
</Window>
